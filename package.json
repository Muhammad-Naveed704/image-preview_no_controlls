{
  "name": "image-previewer",
  "version": "1.0.0",
  "description": "Professional image previewer desktop app - view only, no edit/delete",
  "main": "dist/main/main.js",
  "author": "Image Previewer",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:renderer && npm run dev:main",
    "dev:main": "tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron .",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "npm run build && cross-env NODE_ENV=production electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.imagepreviewer.app",
    "productName": "Image Previewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "fileAssociations": [
        { "ext": "jpg", "name": "JPEG Image", "role": "Viewer" },
        { "ext": "jpeg", "name": "JPEG Image", "role": "Viewer" },
        { "ext": "png", "name": "PNG Image", "role": "Viewer" },
        { "ext": "webp", "name": "WebP Image", "role": "Viewer" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
